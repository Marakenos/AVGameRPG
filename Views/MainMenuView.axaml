<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AVGameRPG.Views.MainMenuView">
	<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
		<Button Width="300" Height="100" Click="OnPlayClick">
			<Image Source="avares://AVGameRPG/Assets/play.png" Stretch="Uniform"/>
		</Button>
		<Button Width="300" Height="100">
			<Image Source="avares://AVGameRPG/Assets/load.png" Stretch="Uniform"/>
		</Button>
		<Button Width="300" Height="100" Click="OnExitClick">
			<Image Source="avares://AVGameRPG/Assets/exit.png" Stretch="Uniform"/>
		</Button>

	</StackPanel>
</UserControl>


